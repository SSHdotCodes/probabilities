# --- Model (OpenCode Go) — reuse the key from pro-ai.ssh.codes ---
OPENCODE_GO_API_KEY=put-the-pro-ai-opencode-go-key-here
OPENCODE_GO_BASE_URL=https://opencode.ai/zen/go/v1
PROB_MODEL=deepseek-v4-pro
PROB_REASONING_EFFORT=medium
PROB_THINKING=enabled
PROB_MAX_TOKENS=6000
PROB_MODEL_TIMEOUT=240
PROB_TEMPERATURE=0.35

# --- Data sources ---
AI_TRACKER_URL=http://127.0.0.1:8788
POLYMARKET_BASE=https://gamma-api.polymarket.com

# --- Storage (keep OUTSIDE the app dir; rasppost release wipes the app dir) ---
PROB_DATA_DIR=/home/sshpro/.pi-servers/servers/probabilities/data

# --- Scheduler ---
PROB_PREDICT_REFRESH_HOURS=12
PROB_RELEASE_CHECK_MINUTES=60
PROB_PREDICT_STAGGER_SECONDS=8
PROB_HIT_TOLERANCE_DAYS=45

# --- Admin (manual refresh / add-model). Blank disables those endpoints. ---
PROB_ADMIN_TOKEN=

PORT=8199
PROB_PUBLIC_URL=https://probabilities.ssh.codes
